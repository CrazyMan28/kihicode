# Kihicode Environment Variables
# Copy this file to .env and fill in your keys

# Required for the agentic loop
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional OpenAI support (if implemented in the future)
OPENAI_API_KEY=your_openai_api_key_here

# Mode: safe (ask for permission) or yolo (just run it)
KIHICODE_MODE=safe
